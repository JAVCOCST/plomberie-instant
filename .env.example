# ──────────────────────────────────────────────────────────────────────────
# .env.example — modèle des variables d'environnement pour le portail
# Toitures VB. Copier en `.env.local` et remplacer les valeurs.
# ──────────────────────────────────────────────────────────────────────────
#
# IMPORTANT : tout ce qui a le préfixe `VITE_` est BUNDLÉ dans le JS client
# et donc PUBLIC. Ne jamais y mettre une service_role key, un secret JWT, etc.
# Les secrets serveur vivent uniquement dans les Edge Functions secrets ou
# dans Vercel env (sans préfixe VITE_).
# ──────────────────────────────────────────────────────────────────────────

# Supabase (public clés anon + URL projet)
VITE_SUPABASE_URL=https://eeradaaxmqzyvxvmahlf.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=eeradaaxmqzyvxvmahlf

# Google Maps / Solar API (clé restreinte par referrer côté Google)
VITE_GOOGLE_MAPS_API_KEY=

# Legacy roof API token (à supprimer une fois la migration v2 finalisée)
VITE_ROOF_API_TOKEN=

# ──────────────────────────────────────────────────────────────────────────
# Feature flags — par défaut tous OFF en prod. Voir docs/feature-flags.md.
# ──────────────────────────────────────────────────────────────────────────

# Vague A — mobile readiness (autosave + offline queue + draft scoping)
# VITE_QUOTE_MOBILE_V2=true
# VITE_QUOTE_FEATURE_AUTOSAVE=true
# VITE_QUOTE_FEATURE_CONFIRM_DESTRUCTIVE=true
# VITE_QUOTE_FEATURE_IMAGE_COMPRESSION=true

# Vague A2 — autofill MAMH + Solar + classify dans le wizard de soumission.
# Quand OFF : aucun mount des hooks, aucune query Brikk/Solar, aucun appel
# à l'edge function solar-api. Le PDF est bit-identique au comportement pré-A2.
# Quand ON : étape 1 auto-remplit 8 champs depuis Brikk MAMH + Solar.
# Voir docs/feature-flags.md pour la liste complète des comportements activés.
# VITE_QUOTE_AUTOFILL_V1=true
