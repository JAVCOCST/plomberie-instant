{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/embauche", "destination": "/embauche.html" },
    { "source": "/embauche/(.*)", "destination": "/embauche.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
